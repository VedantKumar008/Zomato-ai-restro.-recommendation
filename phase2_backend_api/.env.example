# Environment Configuration
# Phase 2: Backend API Development
# Copy this file to .env and fill in your actual values

# LLM Provider Configuration
# Options: openai, anthropic, groq
LLM_PROVIDER=groq

# Groq Configuration (recommended - fast and free)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Anthropic Configuration (if using Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Data Configuration
# Path to processed data from Phase 1 (relative or absolute)
DATA_PATH=../phase1_data_layer/processed_data/zomato_restaurants_processed.csv

# Logging Configuration
LOG_LEVEL=INFO
